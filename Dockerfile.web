FROM node:22.13-alpine AS dependencies
WORKDIR /app

COPY package.json package-lock.json ./
COPY apps/web/package.json apps/web/package.json
RUN npm ci --workspace apps/web --include-workspace-root=false --include=dev

FROM node:22.13-alpine AS builder
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=dependencies /app/node_modules ./node_modules
COPY --from=dependencies /app/apps/web/node_modules ./apps/web/node_modules
COPY package.json package-lock.json ./
COPY apps/web ./apps/web

# NEXT_PUBLIC_* values are embedded into the browser bundle by Next.js. When
# this Dockerfile is used, configure them as Coolify build variables.
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_BASE_RPC_URL
ARG NEXT_PUBLIC_BASE_RPC_FALLBACK_URLS
ARG NEXT_PUBLIC_ROBINHOOD_RPC_URL
ARG NEXT_PUBLIC_ROBINHOOD_RPC_FALLBACK_URLS
ARG NEXT_PUBLIC_MONAD_RPC_URL
ARG NEXT_PUBLIC_MONAD_RPC_FALLBACK_URLS
ARG NEXT_PUBLIC_MONAD_LAUNCH_FACTORY
ARG NEXT_PUBLIC_MONAD_BONDING_CURVE_MARKET
ARG NEXT_PUBLIC_MONAD_GRADUATION_MANAGER
ARG NEXT_PUBLIC_MONAD_LIQUIDITY_LOCKER
ARG NEXT_PUBLIC_MONAD_DIRECT_LAUNCH_FACTORY
ARG NEXT_PUBLIC_MONAD_DIRECT_LIQUIDITY_LOCKER
ARG NEXT_PUBLIC_MONAD_FEE_HOOK
ARG NEXT_PUBLIC_MONAD_DEPLOYMENT_BLOCK
ARG NEXT_PUBLIC_MONAD_DIRECT_DEPLOYMENT_BLOCK
ARG NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID
ARG NEXT_PUBLIC_BLUE_STAKING_GOVERNANCE
ARG NEXT_PUBLIC_BLUE_REVENUE_ROUTER
ARG NEXT_PUBLIC_BLUE_STAKING_VAULT
ARG NEXT_PUBLIC_BLUE_STAKING_DEPLOYMENT_BLOCK
ARG NEXT_PUBLIC_NFT_FEE_POLICY
ARG NEXT_PUBLIC_NFT_DROP_CONTROLLER
ARG NEXT_PUBLIC_NFT_COLLECTION_FACTORY
ARG NEXT_PUBLIC_NFT_MARKETPLACE
ARG NEXT_PUBLIC_NFT_PFP_FACTORY
ARG NEXT_PUBLIC_NFT_PFP_MARKETPLACE
ARG NEXT_PUBLIC_NFT_PFP_DEPLOYMENT_BLOCK
ARG NEXT_PUBLIC_NFT_DEPLOYMENT_BLOCK
ARG NEXT_PUBLIC_NFT_OFFERS
ARG NEXT_PUBLIC_NFT_OFFERS_DEPLOYMENT_BLOCK
ARG NEXT_PUBLIC_NFT_PROTOCOL_VERSION
ARG NEXT_PUBLIC_BASE_WETH
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY
ARG NEXT_PUBLIC_TOKEN_IMAGE_CDN_URL
ARG NEXT_PUBLIC_BASE_DIRECT_LAUNCH_FACTORY
ARG NEXT_PUBLIC_BASE_DIRECT_LIQUIDITY_LOCKER
ARG NEXT_PUBLIC_BASE_DIRECT_DEPLOYMENT_BLOCK
ARG NEXT_PUBLIC_ROBINHOOD_DIRECT_LAUNCH_FACTORY
ARG NEXT_PUBLIC_ROBINHOOD_DIRECT_LIQUIDITY_LOCKER
ARG NEXT_PUBLIC_ROBINHOOD_DIRECT_DEPLOYMENT_BLOCK
ARG NEXT_PUBLIC_FEATURED_TOKENS

ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL \
    NEXT_PUBLIC_BASE_RPC_URL=$NEXT_PUBLIC_BASE_RPC_URL \
    NEXT_PUBLIC_BASE_RPC_FALLBACK_URLS=$NEXT_PUBLIC_BASE_RPC_FALLBACK_URLS \
    NEXT_PUBLIC_ROBINHOOD_RPC_URL=$NEXT_PUBLIC_ROBINHOOD_RPC_URL \
    NEXT_PUBLIC_ROBINHOOD_RPC_FALLBACK_URLS=$NEXT_PUBLIC_ROBINHOOD_RPC_FALLBACK_URLS \
    NEXT_PUBLIC_MONAD_RPC_URL=$NEXT_PUBLIC_MONAD_RPC_URL \
    NEXT_PUBLIC_MONAD_RPC_FALLBACK_URLS=$NEXT_PUBLIC_MONAD_RPC_FALLBACK_URLS \
    NEXT_PUBLIC_MONAD_LAUNCH_FACTORY=$NEXT_PUBLIC_MONAD_LAUNCH_FACTORY \
    NEXT_PUBLIC_MONAD_BONDING_CURVE_MARKET=$NEXT_PUBLIC_MONAD_BONDING_CURVE_MARKET \
    NEXT_PUBLIC_MONAD_GRADUATION_MANAGER=$NEXT_PUBLIC_MONAD_GRADUATION_MANAGER \
    NEXT_PUBLIC_MONAD_LIQUIDITY_LOCKER=$NEXT_PUBLIC_MONAD_LIQUIDITY_LOCKER \
    NEXT_PUBLIC_MONAD_DIRECT_LAUNCH_FACTORY=$NEXT_PUBLIC_MONAD_DIRECT_LAUNCH_FACTORY \
    NEXT_PUBLIC_MONAD_DIRECT_LIQUIDITY_LOCKER=$NEXT_PUBLIC_MONAD_DIRECT_LIQUIDITY_LOCKER \
    NEXT_PUBLIC_MONAD_FEE_HOOK=$NEXT_PUBLIC_MONAD_FEE_HOOK \
    NEXT_PUBLIC_MONAD_DEPLOYMENT_BLOCK=$NEXT_PUBLIC_MONAD_DEPLOYMENT_BLOCK \
    NEXT_PUBLIC_MONAD_DIRECT_DEPLOYMENT_BLOCK=$NEXT_PUBLIC_MONAD_DIRECT_DEPLOYMENT_BLOCK \
    NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=$NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID \
    NEXT_PUBLIC_BLUE_STAKING_GOVERNANCE=$NEXT_PUBLIC_BLUE_STAKING_GOVERNANCE \
    NEXT_PUBLIC_BLUE_REVENUE_ROUTER=$NEXT_PUBLIC_BLUE_REVENUE_ROUTER \
    NEXT_PUBLIC_BLUE_STAKING_VAULT=$NEXT_PUBLIC_BLUE_STAKING_VAULT \
    NEXT_PUBLIC_BLUE_STAKING_DEPLOYMENT_BLOCK=$NEXT_PUBLIC_BLUE_STAKING_DEPLOYMENT_BLOCK \
    NEXT_PUBLIC_NFT_FEE_POLICY=$NEXT_PUBLIC_NFT_FEE_POLICY \
    NEXT_PUBLIC_NFT_DROP_CONTROLLER=$NEXT_PUBLIC_NFT_DROP_CONTROLLER \
    NEXT_PUBLIC_NFT_COLLECTION_FACTORY=$NEXT_PUBLIC_NFT_COLLECTION_FACTORY \
    NEXT_PUBLIC_NFT_MARKETPLACE=$NEXT_PUBLIC_NFT_MARKETPLACE \
    NEXT_PUBLIC_NFT_PFP_FACTORY=$NEXT_PUBLIC_NFT_PFP_FACTORY \
    NEXT_PUBLIC_NFT_PFP_MARKETPLACE=$NEXT_PUBLIC_NFT_PFP_MARKETPLACE \
    NEXT_PUBLIC_NFT_PFP_DEPLOYMENT_BLOCK=$NEXT_PUBLIC_NFT_PFP_DEPLOYMENT_BLOCK \
    NEXT_PUBLIC_NFT_DEPLOYMENT_BLOCK=$NEXT_PUBLIC_NFT_DEPLOYMENT_BLOCK \
    NEXT_PUBLIC_NFT_OFFERS=$NEXT_PUBLIC_NFT_OFFERS \
    NEXT_PUBLIC_NFT_OFFERS_DEPLOYMENT_BLOCK=$NEXT_PUBLIC_NFT_OFFERS_DEPLOYMENT_BLOCK \
    NEXT_PUBLIC_NFT_PROTOCOL_VERSION=$NEXT_PUBLIC_NFT_PROTOCOL_VERSION \
    NEXT_PUBLIC_BASE_WETH=$NEXT_PUBLIC_BASE_WETH \
    NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL \
    NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY \
    NEXT_PUBLIC_TOKEN_IMAGE_CDN_URL=$NEXT_PUBLIC_TOKEN_IMAGE_CDN_URL \
    NEXT_PUBLIC_BASE_DIRECT_LAUNCH_FACTORY=$NEXT_PUBLIC_BASE_DIRECT_LAUNCH_FACTORY \
    NEXT_PUBLIC_BASE_DIRECT_LIQUIDITY_LOCKER=$NEXT_PUBLIC_BASE_DIRECT_LIQUIDITY_LOCKER \
    NEXT_PUBLIC_BASE_DIRECT_DEPLOYMENT_BLOCK=$NEXT_PUBLIC_BASE_DIRECT_DEPLOYMENT_BLOCK \
    NEXT_PUBLIC_ROBINHOOD_DIRECT_LAUNCH_FACTORY=$NEXT_PUBLIC_ROBINHOOD_DIRECT_LAUNCH_FACTORY \
    NEXT_PUBLIC_ROBINHOOD_DIRECT_LIQUIDITY_LOCKER=$NEXT_PUBLIC_ROBINHOOD_DIRECT_LIQUIDITY_LOCKER \
    NEXT_PUBLIC_ROBINHOOD_DIRECT_DEPLOYMENT_BLOCK=$NEXT_PUBLIC_ROBINHOOD_DIRECT_DEPLOYMENT_BLOCK \
    NEXT_PUBLIC_FEATURED_TOKENS=$NEXT_PUBLIC_FEATURED_TOKENS

RUN npm run build -w apps/web

FROM node:22.13-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    HOSTNAME=0.0.0.0 \
    PORT=3000

RUN addgroup --system --gid 1001 nodejs \
  && adduser --system --uid 1001 nextjs

COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

USER nextjs
EXPOSE 3000
HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=4 CMD node -e "fetch('http://127.0.0.1:3000/api/health').then(r=>{if(!r.ok)process.exit(1)}).catch(()=>process.exit(1))"
CMD ["node", "apps/web/server.js"]
